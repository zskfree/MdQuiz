{
  "name": "mdquiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:library": "node ./scripts/build-library.mjs",
    "dev": "npm run build:library && vite --config vite.config.ts",
    "build": "npm run build:library && tsc -b && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  }
}
